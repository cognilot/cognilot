{
  "name": "@cognilot/sdk",
  "version": "0.0.1",
  "description": "Cognilot Core Orchestration SDK. Standalone, ESM-based, cross-platform.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "ai",
    "cognilot",
    "forms",
    "automation",
    "sdk"
  ],
  "author": "Cognilot",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cognilot-org/cognilot.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.15.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^4.1.2"
  }
}
